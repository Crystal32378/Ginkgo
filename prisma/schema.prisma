// Ginkgo Ginkgo Pharmacy — 治療 AI 失憶症的小工具
//
// v2 架構：Distillation Engine
// - Project = 一個專案
// - KnowledgeItem = Brain 中的一條知識（8 種 type，可演化可退役）
// - Pill = 對話 log（不再持有「記憶」，只是蒸餾原料）
// - DistillationLog = 每次蒸餾的推理過程（ritual steps + delta summary）

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 一個專案 = 一條記憶鏈
// 不同專案的記憶互相隔離，避免汙染（這是 ChatGPT Memory 最大的缺陷）
model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  emoji       String   @default("🌿")
  brainVersion Int     @default(0)  // Brain 版本，每次蒸餾 +1
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pills             Pill[]
  knowledgeItems    KnowledgeItem[]
  distillationLogs  DistillationLog[]
}

// Brain 中的一條知識。8 種 type：
// DECISION / CONSTRAINT / PRINCIPLE / DEFINITION / FACT / QUESTION / RISK / HYPOTHESIS
// 每條有 ID（如 D1, C1, DEF1），可演化（update）、可退役（retire）
model KnowledgeItem {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // 顯示用 ID，如 "D1", "C1", "DEF1"。每個 project 內 + type 內獨立編號
  itemId          String

  type            String   // DECISION | CONSTRAINT | PRINCIPLE | DEFINITION | FACT | QUESTION | RISK | HYPOTHESIS

  // 簡短名稱（kebab-case），例如 "memory-structure" "stack-choice"
  name            String

  // 主要內容 — 一句話陳述
  content         String

  // 為什麼 — context、justification
  rationale       String?

  // 信心程度 0-1，主要給 HYPOTHESIS 用，但所有 type 都可填
  confidence      Float?

  // active | retired
  status          String   @default("active")

  // 來源：哪次蒸餾（pill）產生此 item
  sourcePillId    String?
  sourcePill      Pill?    @relation(fields: [sourcePillId], references: [id], onDelete: SetNull)

  // 退役時指向：取代此 item 的 item id
  supersededById  String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([projectId, itemId])
  @@index([projectId, status])
  @@index([projectId, type])
}

// 一顆銀杏藥丸 = 一次對話的 log
// 不再持有「記憶摘要」— 那個角色交給 KnowledgeItem
// Pill 現在只是「這次對話貢獻了什麼」的原料紀錄
model Pill {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // 使用者貼進來的原始對話文本
  conversationText String

  // 標題（一句話描述這次對話發生了什麼）
  title           String?

  // token 數（用於 Diary 統計）
  tokenEstimate   Int      @default(0)

  createdAt       DateTime @default(now())

  // 反向關聯
  distillationLogs DistillationLog[]
  knowledgeItems   KnowledgeItem[]

  @@index([projectId])
}

// 一次蒸餾的推理過程紀錄
// 對應用戶提的「Distillation Diary」— 可檢視的推理紀錄
model DistillationLog {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  pillId          String
  pill            Pill     @relation(fields: [pillId], references: [id], onDelete: Cascade)

  // Brain 版本變化
  brainVersionBefore Int
  brainVersionAfter  Int

  // ritual 步驟（JSON array of {step, detail?, tokens?, status}）
  ritualSteps     String

  // delta 摘要（JSON: {added: N, updated: N, retired: N, byType: {...}}）
  deltaSummary    String

  // profile delta 摘要（JSON: {suggested: N, byType: {...}}）
  profileDeltaSummary String?

  // 統計
  tokensRead      Int      @default(0)  // 這次對話的 token 量
  tokensSavedEstimate Int  @default(0)  // 估算省下多少 token（對話 token - brain token）

  createdAt       DateTime @default(now())

  @@index([projectId])
}

// ============================================================
// User Profile（v0.2 — Task B）
// ============================================================
//
// 設計理念（user 指定）：
// 不是記錄「你是誰」，而是累積「如何與你合作」
// 跨專案、長期生效。錯了比 Project Brain 更危險，所以：
//   - 從對話蒸餾出的 Profile 變更 → 進 PendingProfileSuggestion 等人類 review
//   - 手動新增 → 直接 active
//
// 6 種 type：
//   REASONING_PATTERN  — 思考模式（AI 主動展現）
//   COLLABORATION_PREF — 協作偏好（AI 遵守限制）
//   COMMUNICATION_STYLE — 溝通風格（AI 匹配輸出）
//   WORKING_RHYTHM     — 工作節奏（AI 配合時機）
//   DOMAIN_CONTEXT     — 領域背景（AI 預設理解）
//   PET_PEEVE          — 地雷（AI 主動避開）

model ProfileItem {
  id              String   @id @default(cuid())

  // 顯示用 ID，如 "RP1", "CP1", "CS1"。全局唯一編號
  itemId          String   @unique

  type            String   // REASONING_PATTERN | COLLABORATION_PREF | COMMUNICATION_STYLE | WORKING_RHYTHM | DOMAIN_CONTEXT | PET_PEEVE

  // 簡短名稱（kebab-case），例如 "ask-why-first" "no-repetition"
  name            String

  // 主要內容 — 一句話陳述
  content         String

  // 為什麼 — context、justification
  rationale       String?

  // active | retired
  status          String   @default("active")

  // 來源：manual | suggestion
  source          String   @default("manual")

  // 如果是從 suggestion 核准的，記錄原 suggestion id
  sourceSuggestionId String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// 從對話蒸餾出、等待人類 review 的 Profile 變更建議
// 不直接套用到 ProfileItem — 必須人工 approve 才生效
model PendingProfileSuggestion {
  id              String   @id @default(cuid())

  // add | update | retire
  operation       String

  type            String   // 6 種 type 之一

  name            String?
  content         String?
  rationale       String?

  // 如果是 update/retire，指向既有的 ProfileItem itemId
  existingItemId  String?

  // 來源：哪次蒸餾發現這個建議
  sourcePillId    String?
  sourceProjectId String?
  sourceProjectName String?  // 方便 UI 顯示，denormalized

  // pending | approved | rejected
  status          String   @default("pending")

  // 核准/拒絕時的註記
  reviewNote      String?

  reviewedAt      DateTime?
  createdAt       DateTime @default(now())

  @@index([status])
  @@index([type])
}
