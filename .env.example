DATABASE_URL=file:/home/z/my-project/db/custom.db

# ====== Ginkgo 設定 ======

# API 認證 token — Chrome 擴充或 agent 程式呼叫 API 時必須帶這個
# 留空 = 不檢查（只建議 local 自用時留空）
# 設置 = 所有 /api/projects/** 請求都必須帶 Authorization: Bearer <token>
# 產生隨機 token: openssl rand -hex 32
GINKGO_API_TOKEN=

# LLM backend 選擇：'zai' (預設，免費) 或 'openai' (需設 OPENAI_API_KEY)
# 注意：openai backend 需 server 在 OpenAI 支援的地區
GINKGO_LLM_BACKEND=zai

# OpenAI 設定（當 GINKGO_LLM_BACKEND=openai 時使用）
# 建議用 GPT-4o-mini — 一次對話 30k tokens 約 $0.005 USD
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
